// re2c $INPUT -o $OUTPUT -x --encoding-policy ignore
#include <stdint.h>
#include <stdio.h>
#include "utf16.h"
#define YYCTYPE uint16_t

bool scan(const YYCTYPE* start, const YYCTYPE* const limit) {
	__attribute__((unused)) const YYCTYPE* YYMARKER;
#define YYCURSOR start
Ps:
/*!re2c
	re2c:yyfill:enable = 0;
	Ps = [\x28\x5b\x7b\u0f3a\u0f3c\u169b\u201a\u201e\u2045\u207d\u208d\u2308\u230a\u2329\u2768\u276a\u276c\u276e\u2770\u2772\u2774\u27c5\u27e6\u27e8\u27ea\u27ec\u27ee\u2983\u2985\u2987\u2989\u298b\u298d\u298f\u2991\u2993\u2995\u2997\u29d8\u29da\u29fc\u2e22\u2e24\u2e26\u2e28\u2e42\u2e55\u2e57\u2e59\u2e5b\u3008\u300a\u300c\u300e\u3010\u3014\u3016\u3018\u301a\u301d\ufd3f\ufe17\ufe35\ufe37\ufe39\ufe3b\ufe3d\ufe3f\ufe41\ufe43\ufe47\ufe59\ufe5b\ufe5d\uff08\uff3b\uff5b\uff5f\uff62];
		Ps { goto Ps; }
		* { return YYCURSOR - 1 == limit; }
	*/
}

static const uint32_t chars_Ps[] = {0x28,0x28,0x5b,0x5b,0x7b,0x7b,0xf3a,0xf3a,0xf3c,0xf3c,0x169b,0x169b,0x201a,0x201a,0x201e,0x201e,0x2045,0x2045,0x207d,0x207d,0x208d,0x208d,0x2308,0x2308,0x230a,0x230a,0x2329,0x2329,0x2768,0x2768,0x276a,0x276a,0x276c,0x276c,0x276e,0x276e,0x2770,0x2770,0x2772,0x2772,0x2774,0x2774,0x27c5,0x27c5,0x27e6,0x27e6,0x27e8,0x27e8,0x27ea,0x27ea,0x27ec,0x27ec,0x27ee,0x27ee,0x2983,0x2983,0x2985,0x2985,0x2987,0x2987,0x2989,0x2989,0x298b,0x298b,0x298d,0x298d,0x298f,0x298f,0x2991,0x2991,0x2993,0x2993,0x2995,0x2995,0x2997,0x2997,0x29d8,0x29d8,0x29da,0x29da,0x29fc,0x29fc,0x2e22,0x2e22,0x2e24,0x2e24,0x2e26,0x2e26,0x2e28,0x2e28,0x2e42,0x2e42,0x2e55,0x2e55,0x2e57,0x2e57,0x2e59,0x2e59,0x2e5b,0x2e5b,0x3008,0x3008,0x300a,0x300a,0x300c,0x300c,0x300e,0x300e,0x3010,0x3010,0x3014,0x3014,0x3016,0x3016,0x3018,0x3018,0x301a,0x301a,0x301d,0x301d,0xfd3f,0xfd3f,0xfe17,0xfe17,0xfe35,0xfe35,0xfe37,0xfe37,0xfe39,0xfe39,0xfe3b,0xfe3b,0xfe3d,0xfe3d,0xfe3f,0xfe3f,0xfe41,0xfe41,0xfe43,0xfe43,0xfe47,0xfe47,0xfe59,0xfe59,0xfe5b,0xfe5b,0xfe5d,0xfe5d,0xff08,0xff08,0xff3b,0xff3b,0xff5b,0xff5b,0xff5f,0xff5f,0xff62,0xff62,};

static uint32_t encode_utf16(const uint32_t* ranges, uint32_t ranges_count, uint16_t* s) {
	uint16_t* const s0 = s;
	for (uint32_t i = 0; i < ranges_count; i += 2)
		for (uint32_t j = ranges[i]; j <= ranges[i + 1]; ++j)
			if (j <= re2c::utf16::MAX_1WORD_RUNE) {
				*s++ = j;
			} else {
				*s++ = re2c::utf16::lead_surr(j);
				*s++ = re2c::utf16::trail_surr(j);
			}
	for (uint32_t i = 0; i < 2; ++i) s[i] = 0;
	return s - s0;
}

int main() {
	YYCTYPE* buffer_Ps = new YYCTYPE[160];
	uint32_t buffer_Ps_len = encode_utf16(chars_Ps, sizeof(chars_Ps) / sizeof(uint32_t), buffer_Ps);
	if (!scan(buffer_Ps, buffer_Ps + buffer_Ps_len)) printf("test 'Ps' failed\n");
	delete[] buffer_Ps;
	return 0;
}
